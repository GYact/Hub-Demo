# ============================================
# Supabase Edge Functions - Secrets
# ============================================
# Set these via Supabase CLI:
#   supabase secrets set KEY=value
# Or via Dashboard: Project Settings > Edge Functions > Secrets
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected by Supabase.

# --- AI Provider API Keys ---
# At least one is required for AI features to work.
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key

# --- Google OAuth (for Gmail/Calendar/Drive sync) ---
# Same credentials as VITE_GOOGLE_CLIENT_ID but server-side
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Web Push (VAPID) ---
# Must match the public key in frontend .env
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com

# --- Optional: X/Twitter Post Fetching ---
# XAI_API_KEY=your-xai-api-key

# --- Optional: Slack Integration ---
# SLACK_SIGNING_SECRET=your-slack-signing-secret

# --- Optional: HP (Homepage) Cross-Project Posting ---
# HP_SUPABASE_URL=https://your-hp-project.supabase.co
# HP_SUPABASE_SERVICE_ROLE_KEY=your-hp-service-role-key
