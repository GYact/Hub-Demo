# ============================================
# Hub Relay Server - Environment Variables
# ============================================
# Copy this file to `relay/.env` and fill in your values.
# The relay server bridges the Hub frontend with Claude Code CLI.

PORT=3100

# Auth token for relay API requests
# Generate with: openssl rand -hex 32
RELAY_AUTH_TOKEN=your-auth-token-here

# Directories that Claude Code is allowed to access
ALLOWED_DIR=/path/to/your/developer/directory

# Working directory for AI Company features
AI_COMPANY_CWD=/path/to/your/Hub/clone

# Supabase (same project as frontend)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_PROJECT_REF=your-supabase-project-ref

# Claude Code binary path (optional, defaults to "claude" in PATH)
# CLAUDE_BIN_PATH=/path/to/claude
