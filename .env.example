# ============================================
# Hub - Frontend Environment Variables
# ============================================
# Copy this file to `.env` and fill in your values.
# All VITE_ prefixed variables are exposed to the browser.

# --- Supabase ---
# Create a project at https://supabase.com/dashboard
# Find these in: Project Settings > API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- AI Models (display names used in AI chat provider selector) ---
VITE_GEMINI_MODEL=gemini-3-pro-preview
VITE_OPENAI_MODEL=gpt-5.2
VITE_ANTHROPIC_MODEL=claude-sonnet-4-5
VITE_PERPLEXITY_MODEL=sonar-reasoning-pro

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Type: OAuth 2.0 Client ID (Web application)
# Authorized redirect URIs: https://your-domain.vercel.app/auth/google/callback
# Required APIs: Gmail, Calendar, Drive, Sheets, Docs
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# --- Web Push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# --- Relay Server (optional, for Claude Code integration) ---
# Working directory passed to Claude Code via relay
# VITE_RELAY_WORK_DIR=/path/to/your/Hub/clone

# --- Access Control ---
# Comma-separated list of allowed email addresses
VITE_ALLOWED_EMAILS=your-email@example.com
